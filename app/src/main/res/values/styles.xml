<resources>
    <style name="CustomButton" parent="@android:style/Widget.DeviceDefault.Light.Button">
        <item name="android:backgroundTint">@android:color/white</item>
        <item name="android:textColor">@android:color/black</item>
    </style>

    <style name="ToolbarTitleText" parent="@android:style/TextAppearance.Large">
        <item name="android:textStyle">bold</item>
    </style>

    <style name="ToolbarBase">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">?android:attr/actionBarSize</item>
        <item name="android:background">@android:color/white</item>
        <item name="android:titleTextColor">?android:attr/textColorPrimary</item>
        <item name="android:titleTextAppearance">@style/ToolbarTitleText</item>
        <item name="android:titleMarginStart">16dp</item>
        <item name="android:titleMarginEnd">16dp</item>
    </style>

    <style name="DialogListRoot">
        <item name="android:layout_width">@dimen/dialog_width</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">vertical</item>
        <item name="android:paddingTop">?android:attr/dialogPreferredPadding</item>
        <item name="android:paddingBottom">?android:attr/dialogPreferredPadding</item>
    </style>

    <style name="DialogListTitle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">@dimen/title_margin_bottom</item>
        <item name="android:paddingStart">?android:attr/dialogPreferredPadding</item>
        <item name="android:paddingEnd">?android:attr/dialogPreferredPadding</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">@dimen/text_size_title</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="DialogListContainer">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">vertical</item>
    </style>

    <style name="DialogListSelectableItem">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">?android:attr/selectableItemBackground</item>
        <item name="android:paddingStart">?android:attr/dialogPreferredPadding</item>
        <item name="android:paddingEnd">?android:attr/dialogPreferredPadding</item>
        <item name="android:paddingTop">@dimen/item_padding_vertical</item>
        <item name="android:paddingBottom">@dimen/item_padding_vertical</item>
    </style>

    <style name="DialogListItemText">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_centerVertical">true</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">@dimen/text_size_item</item>
    </style>

    <style name="DialogListDescription">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">@dimen/description_margin_top</item>
        <item name="android:textColor">@color/text_dialog_description</item>
        <item name="android:textSize">@dimen/text_size_description</item>
    </style>

    <style name="DialogListCheckIcon">
        <item name="android:layout_width">@dimen/icon_size</item>
        <item name="android:layout_height">@dimen/icon_size</item>
        <item name="android:layout_alignParentEnd">true</item>
        <item name="android:layout_centerVertical">true</item>
        <item name="android:src">@drawable/ic_check</item>
        <item name="android:visibility">invisible</item>
    </style>

    <style name="DialogListDivider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/divider_height</item>
        <item name="android:layout_marginStart">?android:attr/dialogPreferredPadding</item>
        <item name="android:layout_marginEnd">?android:attr/dialogPreferredPadding</item>
        <item name="android:background">@color/dialog_divider_color</item>
    </style>

    <style name="GroupContainer">
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">vertical</item>
        <item name="android:background">@drawable/bg_group_rounded</item>
        <item name="android:outlineProvider">background</item>
        <item name="android:paddingTop">@dimen/group_padding_vertical</item>
        <item name="android:paddingBottom">@dimen/group_padding_vertical</item>
    </style>

    <style name="ListItemContainer">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:minHeight">?android:attr/listPreferredItemHeight</item>
        <item name="android:paddingStart">?android:attr/listPreferredItemPaddingLeft</item>
        <item name="android:paddingEnd">?android:attr/listPreferredItemPaddingRight</item>
        <item name="android:paddingTop">@dimen/row_padding_vertical</item>
        <item name="android:paddingBottom">@dimen/row_padding_vertical</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>

    <style name="ListItemTitle">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAppearance">?android:attr/textAppearanceMedium</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="ListItemDesc">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textAppearance">?android:attr/textAppearanceSmall</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:layout_marginTop">@dimen/row_body_margin_top</item>
    </style>

    <style name="ListItemSwitch">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@null</item>
        <item name="android:thumb">@drawable/shape_switch_thumb</item>
        <item name="android:track">@drawable/selector_switch_track</item>
        <item name="android:showText">false</item>
    </style>
</resources>
